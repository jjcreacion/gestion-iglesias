-- =============================================
-- SISTEMA DE GESTIÓN DE CONGREGADOS
-- Base de Datos MySQL - Esquema Completo
-- =============================================
SET FOREIGN_KEY_CHECKS = 0;
-- =============================================
-- 1. USUARIOS Y AUTENTICACIÓN
-- =============================================
CREATE TABLE usuarios (
  id CHAR(36) PRIMARY KEY DEFAULT (UUID()),
  email VARCHAR(255) NOT NULL UNIQUE,
  password_hash VARCHAR(255) NOT NULL,
  activo BOOLEAN NOT NULL DEFAULT TRUE,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
-- =============================================
-- 2. TERRITORIOS
-- =============================================
CREATE TABLE territorios (
  id CHAR(36) PRIMARY KEY DEFAULT (UUID()),
  codigo VARCHAR(20) NOT NULL UNIQUE,
  nombre VARCHAR(100) NOT NULL,
  color VARCHAR(7) NOT NULL DEFAULT '#1a365d' COMMENT 'Color hexadecimal distintivo',
  descripcion TEXT,
  activo BOOLEAN NOT NULL DEFAULT TRUE,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
-- =============================================
-- 3. CÉLULAS
-- =============================================
CREATE TABLE celulas (
  id CHAR(36) PRIMARY KEY DEFAULT (UUID()),
  codigo VARCHAR(20) NOT NULL UNIQUE,
  nombre VARCHAR(100) NOT NULL,
  territorio_id CHAR(36) NOT NULL,
  direccion VARCHAR(255),
  dia_reunion ENUM('lunes','martes','miercoles','jueves','viernes','sabado','domingo') DEFAULT 'miercoles',
  hora_reunion TIME,
  activo BOOLEAN NOT NULL DEFAULT TRUE,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  CONSTRAINT fk_celula_territorio FOREIGN KEY (territorio_id) REFERENCES territorios(id) ON DELETE RESTRICT
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
-- =============================================
-- 4. MIEMBROS
-- =============================================
CREATE TABLE miembros (
  id CHAR(36) PRIMARY KEY DEFAULT (UUID()),
  usuario_id CHAR(36) UNIQUE COMMENT 'Referencia al usuario si tiene acceso al sistema',
  
  -- Datos básicos (obligatorios)
  nombre VARCHAR(100) NOT NULL,
  apellido VARCHAR(100) NOT NULL,
  telefono VARCHAR(20),
  direccion VARCHAR(255),
  
  -- Datos complementarios
  cedula VARCHAR(20) UNIQUE,
  fecha_nacimiento DATE,
  estado_civil ENUM('soltero','casado','divorciado','viudo','union_libre') DEFAULT NULL,
  genero ENUM('masculino','femenino') DEFAULT NULL,
  
  -- Datos laborales
  profesion VARCHAR(100),
  oficio VARCHAR(100),
  lugar_trabajo VARCHAR(150),
  talentos TEXT COMMENT 'Lista separada por comas: música, enseñanza, etc.',
  
  -- Datos espirituales
  celula_id CHAR(36),
  fecha_conversion DATE,
  invitado_por_id CHAR(36) COMMENT 'Miembro que lo invitó',
  consolidador_id CHAR(36) COMMENT 'Miembro asignado como consolidador',
  
  -- Formación espiritual (booleanos y fechas)
  encuentro BOOLEAN NOT NULL DEFAULT FALSE,
  fecha_encuentro DATE,
  bautismo BOOLEAN NOT NULL DEFAULT FALSE,
  fecha_bautismo DATE,
  
  -- Escuela de Líderes
  escuela_fundamento ENUM('no_iniciado','en_curso','completado') NOT NULL DEFAULT 'no_iniciado',
  escuela_familia ENUM('no_iniciado','en_curso','completado') NOT NULL DEFAULT 'no_iniciado',
  escuela_vision ENUM('no_iniciado','en_curso','completado') NOT NULL DEFAULT 'no_iniciado',
  escuela_intercesion ENUM('no_iniciado','en_curso','completado') NOT NULL DEFAULT 'no_iniciado',
  escuela_liderazgo ENUM('no_iniciado','en_curso','completado') NOT NULL DEFAULT 'no_iniciado',
  escuela_consolidacion ENUM('no_iniciado','en_curso','completado') NOT NULL DEFAULT 'no_iniciado',
  
  -- Otras formaciones
  escuela_profetica ENUM('no_iniciado','en_curso','completado') NOT NULL DEFAULT 'no_iniciado',
  universidad_am ENUM('no_iniciado','en_curso','completado') NOT NULL DEFAULT 'no_iniciado',
  escuela_teologica ENUM('no_iniciado','en_curso','completado') NOT NULL DEFAULT 'no_iniciado',
  
  -- Estado del miembro
  estado ENUM('activo','inactivo','trasladado','baja') NOT NULL DEFAULT 'activo',
  foto_url VARCHAR(500),
  notas TEXT,
  
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  
  CONSTRAINT fk_miembro_usuario FOREIGN KEY (usuario_id) REFERENCES usuarios(id) ON DELETE SET NULL,
  CONSTRAINT fk_miembro_celula FOREIGN KEY (celula_id) REFERENCES celulas(id) ON DELETE SET NULL,
  CONSTRAINT fk_miembro_invitado_por FOREIGN KEY (invitado_por_id) REFERENCES miembros(id) ON DELETE SET NULL,
  CONSTRAINT fk_miembro_consolidador FOREIGN KEY (consolidador_id) REFERENCES miembros(id) ON DELETE SET NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
CREATE INDEX idx_miembro_celula ON miembros(celula_id);
CREATE INDEX idx_miembro_estado ON miembros(estado);
CREATE INDEX idx_miembro_consolidador ON miembros(consolidador_id);
