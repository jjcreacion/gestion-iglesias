-- =============================================
-- VISTAS ÚTILES PARA REPORTES
-- =============================================
-- Vista: Resumen de miembros por célula con conteo de guías
CREATE VIEW v_miembros_resumen AS
SELECT 
  m.id,
  m.nombre,
  m.apellido,
  m.estado,
  m.celula_id,
  c.nombre AS celula_nombre,
  t.nombre AS territorio_nombre,
  t.codigo AS territorio_codigo,
  COALESCE(g.guias_completadas, 0) AS guias_completadas,
  m.encuentro,
  m.bautismo,
  m.fecha_conversion,
  cons.nombre AS consolidador_nombre,
  cons.apellido AS consolidador_apellido
FROM miembros m
LEFT JOIN celulas c ON m.celula_id = c.id
LEFT JOIN territorios t ON c.territorio_id = t.id
LEFT JOIN miembros cons ON m.consolidador_id = cons.id
LEFT JOIN (
  SELECT miembro_id, COUNT(*) AS guias_completadas 
  FROM miembro_guias WHERE completada = TRUE 
  GROUP BY miembro_id
) g ON m.id = g.miembro_id;
-- Vista: Reporte de asistencia dominical
CREATE VIEW v_reporte_asistencia AS
SELECT 
  s.fecha,
  s.tipo,
  c.nombre AS celula,
  t.nombre AS territorio,
  reg.nombre AS registrado_por_nombre,
  asv.ofrendas,
  COUNT(CASE WHEN ad.presente = TRUE AND ad.tipo_asistente = 'miembro' THEN 1 END) AS presentes,
  COUNT(CASE WHEN ad.presente = TRUE AND ad.tipo_asistente = 'primera_vez' THEN 1 END) AS primera_vez,
  COUNT(CASE WHEN ad.presente = TRUE AND ad.tipo_asistente = 'visita' THEN 1 END) AS visitas,
  COUNT(CASE WHEN ad.presente = TRUE THEN 1 END) AS total_asistentes
FROM asistencia_servicio asv
JOIN servicios s ON asv.servicio_id = s.id
JOIN celulas c ON asv.celula_id = c.id
JOIN territorios t ON c.territorio_id = t.id
JOIN miembros reg ON asv.registrado_por_id = reg.id
LEFT JOIN asistencia_detalle ad ON asv.id = ad.asistencia_servicio_id
GROUP BY s.fecha, s.tipo, c.nombre, t.nombre, reg.nombre, asv.ofrendas;
-- Vista: Ganados del mes
CREATE VIEW v_ganados_mes AS
SELECT 
  DATE_FORMAT(g.fecha_ganado, '%Y-%m') AS mes,
  g.contexto,
  c.nombre AS celula,
  t.nombre AS territorio,
  CONCAT(gp.nombre, ' ', gp.apellido) AS ganado_por,
  COUNT(*) AS total_ganados
FROM ganados g
JOIN miembros gp ON g.ganado_por_id = gp.id
LEFT JOIN celulas c ON g.celula_id = c.id
LEFT JOIN territorios t ON c.territorio_id = t.id
GROUP BY mes, g.contexto, c.nombre, t.nombre, CONCAT(gp.nombre, ' ', gp.apellido);
-- Vista: Estado de formación
CREATE VIEW v_formacion_resumen AS
SELECT
  t.nombre AS territorio,
  c.nombre AS celula,
  COUNT(*) AS total_miembros,
  SUM(CASE WHEN m.encuentro = TRUE THEN 1 ELSE 0 END) AS con_encuentro,
  SUM(CASE WHEN m.encuentro = FALSE THEN 1 ELSE 0 END) AS sin_encuentro,
  SUM(CASE WHEN m.bautismo = TRUE THEN 1 ELSE 0 END) AS bautizados,
  SUM(CASE WHEN m.escuela_fundamento = 'completado' 
        AND m.escuela_familia = 'completado' 
        AND m.escuela_vision = 'completado'
        AND m.escuela_intercesion = 'completado'
        AND m.escuela_liderazgo = 'completado'
        AND m.escuela_consolidacion = 'completado' THEN 1 ELSE 0 END) AS graduados_escuela_lideres,
  SUM(CASE WHEN m.escuela_fundamento != 'no_iniciado' 
        AND NOT (m.escuela_fundamento = 'completado' 
                AND m.escuela_familia = 'completado'
                AND m.escuela_vision = 'completado'
                AND m.escuela_intercesion = 'completado'
                AND m.escuela_liderazgo = 'completado'
                AND m.escuela_consolidacion = 'completado') THEN 1 ELSE 0 END) AS en_escuela_lideres,
  SUM(CASE WHEN m.escuela_profetica != 'no_iniciado' THEN 1 ELSE 0 END) AS en_escuela_profetica,
  SUM(CASE WHEN m.universidad_am != 'no_iniciado' THEN 1 ELSE 0 END) AS en_universidad_am,
  SUM(CASE WHEN m.escuela_teologica != 'no_iniciado' THEN 1 ELSE 0 END) AS en_escuela_teologica
FROM miembros m
LEFT JOIN celulas c ON m.celula_id = c.id
LEFT JOIN territorios t ON c.territorio_id = t.id
WHERE m.estado = 'activo'
GROUP BY t.nombre, c.nombre;
